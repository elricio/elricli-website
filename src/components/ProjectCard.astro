---
interface Props {
  title: string;
  description: string;
  tags: string[];
  github?: string;
  demo?: string;
}

const { title, description, tags, github, demo } = Astro.props;
---

<article class="flex flex-col rounded-xl border border-slate-200 bg-white p-6 transition-shadow hover:shadow-md dark:border-slate-800 dark:bg-slate-900">
  <h3 class="mb-2 text-xl font-bold">{title}</h3>
  <p class="mb-4 flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
    {description}
  </p>

  <div class="mb-4 flex flex-wrap gap-2">
    {
      tags.map((tag) => (
        <span class="rounded-md bg-slate-100 px-2 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-300">
          {tag}
        </span>
      ))
    }
  </div>

  <div class="flex gap-3">
    {
      github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-indigo-600 hover:underline dark:text-indigo-400"
        >
          GitHub
        </a>
      )
    }
    {
      demo && (
        <a
          href={demo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-indigo-600 hover:underline dark:text-indigo-400"
        >
          在线预览
        </a>
      )
    }
  </div>
</article>
