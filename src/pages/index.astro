---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout>
  <Header />

  <main>
    <Hero />

    <section class="mx-auto max-w-5xl px-6 py-16">
      <div class="mb-8 flex items-end justify-between">
        <h2 class="text-2xl font-bold md:text-3xl">最新博客</h2>
        <a href="/blog" class="text-sm font-medium text-indigo-600 hover:underline dark:text-indigo-400">查看全部</a>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <BlogCard post={post} />)}
      </div>
    </section>

    <!-- 项目入口暂时隐藏
    <section class="mx-auto max-w-5xl px-6 py-16">
      <div class="mb-8 flex items-end justify-between">
        <h2 class="text-2xl font-bold md:text-3xl">精选项目</h2>
        <a href="/projects" class="text-sm font-medium text-indigo-600 hover:underline dark:text-indigo-400">查看全部</a>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => <ProjectCard {...project} />)}
      </div>
    </section>
    -->
  </main>

  <Footer />
</Layout>
