---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const skills = [
  'TypeScript',
  'React',
  'Vue',
  'Astro',
  'Tailwind CSS',
  'Node.js',
  'Next.js',
  'Vite',
  'Git',
  'Figma'
];
---

<Layout title="关于我 | Elric Li" description="了解前端开发工程师 Elric Li 的技术背景与经历。">
  <Header />

  <main class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <h1 class="mb-6 text-3xl font-bold md:text-4xl">关于我</h1>

    <div class="max-w-none">
      <p class="text-lg leading-relaxed text-slate-600 dark:text-slate-300">
        你好，我是 <strong>Elric Li</strong>，一名热爱技术与设计的前端开发工程师。我喜欢把复杂的交互拆成清晰的代码，也关注性能、可访问性和用户体验。
      </p>

      <p class="leading-relaxed text-slate-600 dark:text-slate-300">
        工作之余，我会在这里记录学习心得、项目复盘和技术观察。如果你对我的经历或某个项目感兴趣，欢迎通过
        <a href="/contact" class="text-indigo-600 hover:underline dark:text-indigo-400">联系页面</a>
        找到我。
      </p>
    </div>

    <h2 class="mb-4 mt-12 text-xl font-bold">技术栈</h2>
    <div class="flex flex-wrap gap-3">
      {
        skills.map((skill) => (
          <span class="rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm dark:border-slate-800 dark:bg-slate-900 dark:text-slate-300">
            {skill}
          </span>
        ))
      }
    </div>

    <h2 class="mb-4 mt-12 text-xl font-bold">经历</h2>
    <ul class="space-y-4">
      <li class="rounded-lg border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-900">
        <div class="font-semibold">高级前端工程师</div>
        <div class="text-sm text-slate-500 dark:text-slate-400">某科技公司 · 2022 - 至今</div>
      </li>
      <li class="rounded-lg border border-slate-200 bg-white p-4 dark:border-slate-800 dark:bg-slate-900">
        <div class="font-semibold">前端开发工程师</div>
        <div class="text-sm text-slate-500 dark:text-slate-400">某互联网公司 · 2019 - 2022</div>
      </li>
    </ul>
  </main>

  <Footer />
</Layout>
